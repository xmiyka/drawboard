{
  "overrides": [
    {
      "files": ["src/**/*.{ts,tsx}"],
      "rules": {
        "@typescript-eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["../../drawboard", "../../../packages/drawboard", "@drawboard/drawboard"],
                "message": "Do not import from '@drawboard/drawboard' package anything but types, as this package must be independent.",
                "allowTypeImports": true
              }
            ]
          }
        ]
      }
    }
  ]
}
