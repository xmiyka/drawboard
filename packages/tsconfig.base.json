{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "paths": {
      "@drawboard/common": ["./common/src/index.ts"],
      "@drawboard/common/*": ["./common/src/*"],
      "@drawboard/element": ["./element/src/index.ts"],
      "@drawboard/element/*": ["./element/src/*"],
      "@drawboard/drawboard": ["./drawboard/index.tsx"],
      "@drawboard/drawboard/*": ["./drawboard/*"],
      "@drawboard/math": ["./math/src/index.ts"],
      "@drawboard/math/*": ["./math/src/*"],
      "@drawboard/utils": ["./utils/src/index.ts"],
      "@drawboard/utils/*": ["./utils/src/*"]
    }
  }
}
