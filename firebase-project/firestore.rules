rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Realtime collaboration scenes
    //
    // Rooms are public by design — the room key lives only in the URL hash
    // and is never sent to the server.  All scene data is AES-encrypted by
    // the client before it is written here.
    // -----------------------------------------------------------------------
    match /scenes/{sceneId} {
      allow get, write: if true;
      allow list: if false;
    }

    // -----------------------------------------------------------------------
    // User profiles
    //
    // A minimal profile document is upserted on every sign-in.  Only the
    // owning user may read or write their own profile.
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // ---------------------------------------------------------------------
      // User boards
      //
      // Board documents store: name, timestamps, elements[], appState, and
      // fileIds (IDs of binary files kept in Firebase Storage).  Only the
      // owning user may access their boards.
      // ---------------------------------------------------------------------
      match /boards/{boardId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;

        // Validate writes to prevent accidental schema drift.
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasAll(['id', 'name', 'createdAt', 'updatedAt']);

        allow update: if request.auth != null
                      && request.auth.uid == userId;
      }
    }

    // -----------------------------------------------------------------------
    // Deny everything else by default.
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
